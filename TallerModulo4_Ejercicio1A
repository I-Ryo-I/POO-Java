// Java
public void subirNivel() {
    this.nivel = this.nivel + 1;       // ← 1
    this.hp += 10;                     // ← hp
}

// Recorrido:
for (int i = 0; i < equipo.length; i++) {
    if (equipo[i] != null && equipo[i].getNivel() < 10) {  // ← getNivel
        equipo[i].subirNivel();
    }
}
